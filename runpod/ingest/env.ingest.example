# Copy to .env.ingest on the pod (or use RunPod env UI). Do not commit real secrets.

R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET=r2-videos

GITHUB_REPO=kentangwire/projektmelody-archive
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

WORK_DIR=/work
IDLE=1

# Required for NVENC — without "video", libnvidia-encode is not mounted and h264_nvenc is missing
NVIDIA_DRIVER_CAPABILITIES=compute,video,utility
NVIDIA_VISIBLE_DEVICES=all

# Per-job (or pass to /app/run-url.sh instead of setting here):
# URL=https://example.com/my-stream.mp4
# DATE=2026-06-02
