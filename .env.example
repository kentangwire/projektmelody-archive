DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require
# GitHub Actions secrets (Settings → Secrets and variables → Actions):
#   DATABASE_URL     — neon-sync + deploy-pages (optional secret refresh)
#   CLOUDFLARE_API_TOKEN
#   CLOUDFLARE_ACCOUNT_ID
# Also set DATABASE_URL on Cloudflare Pages (Settings → Environment variables)
# so /api/videos/* functions can reach Neon directly (no Render).
CORS_ORIGINS=https://projektmelody.cc,https://www.projektmelody.cc
